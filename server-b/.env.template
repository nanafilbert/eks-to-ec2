REGISTRY=ghcr.io/yourusername
VERSION=latest

# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change-me
AIRFLOW_SECRET_KEY=change-me-random-string
AIRFLOW_ADMIN_PASSWORD=change-me-strong-password

# Airflow DB (separate from app DB, on Server A via WireGuard)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me-strong-password

# AWS (Instance Profile handles this in production — leave blank)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_SCRAPER_BUCKET=your-scraper-bucket
